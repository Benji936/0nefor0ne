{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.mjs && vite-ssg build",
    "preview": "vite preview",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "sitemap:large": "node scripts/generate-sitemap.mjs --limit=500",
    "cards:bulk-upload": "node scripts/r2/bulk-upload.mjs",
    "cards:sync": "node scripts/r2/sync-from-api.mjs",
    "cards:tips": "node scripts/yugipedia-tips.mjs",
    "cards:banlist": "node scripts/yugipedia-banlist.mjs",
    "edopro:index": "node scripts/edopro/build-effect-index.mjs --out public/data/effect-index.json",
    "edopro:spike": "node scripts/edopro/spike.mjs",
    "edopro:card-db": "node scripts/edopro/build-card-db.mjs",
    "copy:engine": "node scripts/copy-engine.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@supabase/supabase-js": "^2.57.4",
    "@tailwindcss/vite": "^4.1.4",
    "@unhead/vue": "^2.1.15",
    "axios": "^1.9.0",
    "ocgcore-wasm": "^0.1.2",
    "tailwindcss": "^4.1.4",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.5.0",
    "vuetify": "^3.9.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "dotenv": "^16.4.5",
    "sass": "^1.91.0",
    "vite": "^6.2.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.8"
  }
}
