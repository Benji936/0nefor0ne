# Discord Bot — Environment Variables
# Copy this file to .env and fill in your values.

# ── Discord ──────────────────────────────────────────────────────────────────
# From: discord.com/developers → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# The Forum Channel ID where users post their announces
# Right-click the channel in Discord → Copy Channel ID
# (requires Developer Mode: User Settings → Advanced → Developer Mode)
DISCORD_ANNOUNCES_CHANNEL_ID=your-channel-id-here

# ── Supabase (server-side only — NEVER expose in the frontend) ────────────────
# From: Supabase Dashboard → Settings → API → service_role key
SUPABASE_URL=https://sxteuctysfiwripnaozi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of your web app (no trailing slash)
APP_URL=https://0nefor.one
