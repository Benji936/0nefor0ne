# Discord Bot — Environment Variables
# Copy this file to .env and fill in your values.

# ── Discord ──────────────────────────────────────────────────────────────────
# From: discord.com/developers → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Optional fallback channel ID used for servers that haven't run !setchannel yet.
# In multi-server mode, each server sets its own channel via the !setchannel command.
# Leave blank if you want every server to be required to run !setchannel first.
DISCORD_ANNOUNCES_CHANNEL_ID=

# ── Supabase (server-side only — NEVER expose in the frontend) ────────────────
# From: Supabase Dashboard → Settings → API → service_role key
SUPABASE_URL=https://sxteuctysfiwripnaozi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of your web app (no trailing slash)
APP_URL=https://0nefor.one
