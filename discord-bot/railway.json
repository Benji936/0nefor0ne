# Railway deployment config — auto-detected as Node.js, no Dockerfile needed.
# Railway will run `npm start` (node index.js) automatically.
{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "node index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
